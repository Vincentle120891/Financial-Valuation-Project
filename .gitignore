*.log

# Environment variables
.env
.env.local
.env.*

# IDE specific
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS generated files
.DS_Store
Thumbs.db

# Compiled files
*.o
*.obj
*.so
*.a
*.dll
*.exe
*.out
```