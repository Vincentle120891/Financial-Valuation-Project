```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Dependencies
venv/
.venv/
node_modules/

# Build/dist directories
build/
dist/
target/

# Environment files
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Coverage reports
.coverage
coverage/
htmlcov/

# Python cache
.mypy_cache/
.pytest_cache/
*.pyc
*.pyo
*.pyd

# OS generated files
.DS_Store
Thumbs.db
```