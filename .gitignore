```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.min.js
*.min.css
*.bundle.js

# Environment variables
.env
.env.local
.env.*

# Logs
*.log

# Coverage reports
coverage/
htmlcov/
.coverage

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/

# Compiled and binary files
*.exe
*.dll
*.so
*.a
*.obj
*.out

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```