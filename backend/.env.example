# =============================================================================
# Financial Valuation Backend - Environment Variables
# Professional-grade valuation platform configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=8000
DEBUG=true

# -----------------------------------------------------------------------------
# API Configuration (Externalized Settings)
# -----------------------------------------------------------------------------
API_PREFIX=/api
API_VERSION=v1
# For reverse proxy setups (e.g., behind nginx)
# API_ROOT_PATH=/valuation-api

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME="Valuation Engine API"
APP_VERSION=2.0.0
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Financial Data APIs (Required)
# -----------------------------------------------------------------------------
ALPHA_VANTAGE_KEY=demo
# Get your free key at: https://www.alphavantage.co/support/#api-key

# -----------------------------------------------------------------------------
# AI APIs (Optional - will fallback to mock data if not provided)
# -----------------------------------------------------------------------------

# Google Gemini API - Primary AI provider
# Get your free key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Groq API - Fallback AI provider (Llama 3)
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# AI Configuration (optional, uses defaults if not set)
# -----------------------------------------------------------------------------
AI_PRIMARY_MODEL=gemini
AI_FALLBACK_MODEL=groq
AI_CONFIDENCE_THRESHOLD=0.7

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
# LOG_FILE=/var/log/valuation-api/app.log

# -----------------------------------------------------------------------------
# Session Management
# -----------------------------------------------------------------------------
SESSION_TTL_HOURS=24
MAX_SESSIONS_PER_USER=10

# Redis (optional, for production session storage)
# REDIS_URL=redis://localhost:6379/0
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
