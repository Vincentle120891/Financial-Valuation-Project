--- .gitignore (原始)
```
# Compiled and build artifacts
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
node_modules/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage reports
coverage/
htmlcov/
.coverage

# Python specific
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
.installed.cfg
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage.*
.cache/
nosetests.xml
coverage.xml
*.cover
*.log
.git/

# Distribution / packaging
.Python
*.so
.Python
*.egg-info/
.eggs/
.installed.cfg
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage.*
.cache/
nosetests.xml
coverage.xml
*.cover
*.log
.git/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Pytest
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints

# Local configuration file (specific to avoid committing sensitive data)
.env.local
